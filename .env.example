# Telegram BotFather'dan olingan token
BOT_TOKEN=7123456789:AAHk3jXX-exampleTokenHereXXXXXXXXXXX

# Bito integratsiya bo'limidan olingan API kalit
BITO_API_KEY=sizning_bito_api_kalitingiz

# Bito API manzili (production)
BITO_API_BASE=https://api.bito.uz/integration-api/integration/api/v2

# Sizning ERP'dagi organization_id (bitta tashkilot bo'lsa shuni qo'ying)
BITO_ORGANIZATION_ID=sizning_organization_id

# Sizning ERP'dagi asosiy ombor (warehouse) id
BITO_WAREHOUSE_ID=sizning_warehouse_id

# Web App joylashgan domen (HTTPS bo'lishi shart)
WEBAPP_URL=https://shop.birlik.bito.uz

# Server porti
PORT=3000
